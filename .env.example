# Convex deployment URL (set by init_app_project tool or npx convex dev)
VITE_CONVEX_URL=

# For local development with npx convex dev
# CONVEX_DEPLOY_KEY=

# Auth private key (RSA 2048, generated automatically)
# AUTH_PRIVATE_KEY=

# Viktor Spaces access mode: public, space_auth, or viktor_auth
VITE_VIKTOR_SPACES_ACCESS_MODE=public

# Stable Space id from Viktor, required when VITE_VIKTOR_SPACES_ACCESS_MODE=viktor_auth
VITE_VIKTOR_SPACES_SPACE_ID=

# Viktor backend URL, required when VITE_VIKTOR_SPACES_ACCESS_MODE=viktor_auth
VITE_VIKTOR_SPACES_API_URL=

# Optional explicit Viktor OAuth client id. Defaults to space-$VITE_VIKTOR_SPACES_SPACE_ID.
VITE_VIKTOR_AUTH_CLIENT_ID=
